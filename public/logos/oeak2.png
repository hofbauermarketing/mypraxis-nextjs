	outline-offset: 2px !important;
	box-shadow: 0 0 0 3px white !important;
}

.desktop-menu .navigation-item.keyboard-active button.caret:focus {
	outline: 2px solid white !important;
	outline-offset: 2px !important;
	box-shadow: 0 0 0 3px #006eb3 !important;
}

